-                    value = $0
-                    sub(/^[[:space:]]*(export[[:space:]]+)?LOCAL_API_KEY[[:space:]]*=[[:space:]]*/, "", value)
-                    print value
-                    exit
-                }
-            ' "$ENV_FILE"
-        )"
-
-        case "$LOCAL_API_KEY" in
-            \"*\")
-                LOCAL_API_KEY="${LOCAL_API_KEY#\"}"
-                LOCAL_API_KEY="${LOCAL_API_KEY%\"}"
-                ;;
-            \'*\')
-                LOCAL_API_KEY="${LOCAL_API_KEY#\'}"
-                LOCAL_API_KEY="${LOCAL_API_KEY%\'}"
-                ;;
-        esac
+        LOCAL_API_KEY="$($PYTHON "$INSTALL_HELPERS" read_env_key "$ENV_FILE")"
     fi
 fi
 
