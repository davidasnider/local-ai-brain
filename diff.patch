+        ("  LOCAL_API_KEY  =  another_key  ", "another_key"),  # pragma: allowlist secret
+        ('LOCAL_API_KEY="key_with_\\"_quotes"', 'key_with_"_quotes'),  # pragma: allowlist secret
+        ("LOCAL_API_KEY='key_with_\\'_quotes'", "key_with_'_quotes"),  # pragma: allowlist secret
+    ]
+
+    for file_content, expected_key in test_cases:
